# === AgroVision RAG Service ===

# General
APP_ENV=development
APP_PORT=8001

# Base de datos (para persistir estado de documentos e indice_rag_documentos)
DATABASE_URL=postgresql://agrovision_user:agrovision_pass_2026@localhost:5432/agrovision_db

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=agrovision_docs

# LLM Generation
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# Embedding
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# Retrieval
RETRIEVER_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Backend NestJS
BACKEND_API_URL=http://localhost:4000/api/v1
